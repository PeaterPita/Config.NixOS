{

    # Key binds map leader
  # globalOpts = { mapleader = " "; };

  opts = {

    # Numbers
    number = true;
    relativenumber = true;

    # Set tab to default 4 instead of 2
    tabstop = 4;
    softtabstop = 4;
    shiftwidth = 4;

    # Replace tab with spaces
    expandtab = true;

    # Use smart indenting
    smartindent = true;

    # Line wrap disabled
    wrap = false;

    # SwapFile & backup disabled
    swapfile = false;
    backup = false;

    # Searching (single highlight ++ increment search string)
    hlsearch = false;
    incsearch = true;

    # Enable 24-bit RGB colors
    termguicolors = true;

    # Always keep 10 lines below and above current
    scrolloff = 10;

    # column for signs like git blame
    signcolumn = "yes";

    # ms between updates
    updatetime = 50;

    # Folds
    foldlevel = 99;
    foldlevelstart = 99;



    # Spell check
    spell = true;

  };

}
